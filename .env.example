# VITE_SUPABASE_URL: Supabase project URL (public, embedded in client bundle)
VITE_SUPABASE_URL=your_project_url

# VITE_SUPABASE_ANON_KEY: Supabase anonymous key (public, embedded in client bundle)
VITE_SUPABASE_ANON_KEY=your_anon_key

# Server-side only (DO NOT prefix with VITE_ — would embed in public JS):
# SUPABASE_SERVICE_ROLE_KEY — for scraper scripts / GitHub Actions
# GEMINI_API_KEY — for server-side AI features
